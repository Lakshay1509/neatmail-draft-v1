# ────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# ────────────────────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Pinecone ─────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk-...
PINECONE_INDEX_NAME=neatmail-context
PINECONE_ENVIRONMENT=us-east-1        # match your Pinecone serverless region

# ── Email history ────────────────────────────────────────────────
HISTORY_DAYS=60
MAX_CONTEXT_VECTORS=5
CHUNK_MAX_TOKENS=500

# ── App ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_ENV=production                    # set to "development" to expose /docs

DASHBOARD_API_KEY=